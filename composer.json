{
  "name": "mzeahmed/wp-noticoel",
  "description": "A lightweight event publisher for WordPress that forwards application events to a Noticoel hub over HTTP.",
  "type": "wordpress-plugin",
  "license": "MIT",
  "keywords": [
    "wordpress",
    "plugin"
  ],
  "autoload": {
    "psr-4": {
      "WpNoticoel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WpNoticoel\\CsFixer\\": "tools/CsFixer/"
    }
  },
  "authors": [
    {
      "name": "Ahmed Mze",
      "email": "houdjiva@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpstan/phpstan": "^2.2",
    "rector/rector": "^2.5",
    "szepeviktor/phpstan-wordpress": "^2.0"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "lint": "php-cs-fixer fix --dry-run --diff",
    "lint:fix": "php-cs-fixer fix --diff"
  }
}
