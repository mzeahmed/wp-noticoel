includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
parameters:
    phpVersion: 80300
    fileExtensions:
        - php
    level: 6

    treatPhpDocTypesAsCertain: false

    bootstrapFiles:
        - phpstan.bootstrap.php

    # On a CI runner with many cores but little RAM, several parallel workers
    # (each reloading the WordPress bootstrap + type graph) can crash with an
    # OOM. We run sequentially instead, so there is only ever one memory
    # footprint at a time, regardless of the container's actual RAM.
    parallel:
        maximumNumberOfProcesses: 1

    paths:
        - src
    excludePaths: